msgstr "Impossible d’ouvrir le lien"

#: src/kgx-terminal.c:360
#, c-format
msgctxt "spad-message"
msgid ""
"The link “<a href=\"%s\">%s</a>” uses the protocol “%s”, for which no apps "
"are installed."
msgstr ""
"Le lien « <a href=\"%s\">%s</a> » utilise le protocole « %s », pour lequel "
"aucune application n’est installée."

#: src/kgx-terminal.c:373
#, c-format
msgctxt "spad-message"
